# ===========================
# Unity .gitignore
# Unity 6000.0.72f1
# ===========================

# Generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size
[Mm]emory[Cc]aptures/

# Recordings can get excessive in size
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Crash report data
[Cc]rash[Rr]eports/

# Never ignore Asset meta data (generated by Unity)
!/[Aa]ssets/**

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Editor-specific project settings (local machine only)
/[Pp]roject[Ss]ettings/ProjectVersion.txt

# Visual Studio / Rider cache
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Nuget
/[Pp]ackages/
!default.unity3ddb

# TextMeshPro (keep the asset, ignore nothing extra)
# Uncomment below only if you want to ignore TMP's included examples:
# Assets/TextMesh Pro/Examples & Extras/

# IL2CPP
/[Ii][Ll]2[Cc][Pp][Pp]/

# Android
*.keystore

# WebGL
[Ww]eb[Gg][Ll]/

# Consoles (if you have dev kits)
# Assets/PS4
# Assets/XboxOne

# Autogenerated VS/Rider solution files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj

# BuiltInShaders (Unity downloads these on demand)
Built-in Shaders*/